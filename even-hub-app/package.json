{
  "name": "rp-glass-transcribe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Even Realities G2 app: live transcription shown on the glasses and recorded to Notion.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "pack": "evenhub pack app.json dist -o rp-transcribe.ehpk",
    "simulate": "evenhub-simulator --url http://localhost:5173"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.10"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.12",
    "@evenrealities/evenhub-simulator": "^0.7.2",
    "typescript": "^5.7.0",
    "vite": "^5.4.0"
  }
}
